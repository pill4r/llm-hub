    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.9.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20230518.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
